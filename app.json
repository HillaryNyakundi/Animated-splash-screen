{
  "expo": {
    "name": "medium-splash",
    "slug": "medium-splash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/medium.png",
    "scheme": "mediumsplash",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.avid10187.mediumsplash"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/medium.png",
        "backgroundColor": "#0B1221"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.avid10187.mediumsplash"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1221",
          "image": "./assets/images/medium.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
